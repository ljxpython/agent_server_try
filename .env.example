# ==================== Runtime proxy ====================
# LangGraph runtime base URL.
# Local dev usually keeps the default runtime on 127.0.0.1:8123.
LANGGRAPH_UPSTREAM_URL=http://127.0.0.1:8123

# Optional upstream API key.
# Leave empty for local runtime; set it only if your upstream requires x-api-key.
LANGGRAPH_UPSTREAM_API_KEY=

# ==================== HTTP proxy ====================
# Upstream request timeout in seconds.
# Keep 300 for long-running graph runs unless your environment needs shorter timeouts.
PROXY_TIMEOUT_SECONDS=300

# Browser origins allowed by FastAPI CORS middleware.
# Use * only for local development; use exact origins in staging/production.
PROXY_CORS_ALLOW_ORIGINS=*

# Retry count for upstream passthrough requests.
# 0 disables retries; 1 is a conservative default.
PROXY_UPSTREAM_RETRIES=1

# Backend log verbosity.
# Typical values: DEBUG / INFO / WARNING / ERROR.
PROXY_LOG_LEVEL=INFO

# Expose /docs, /redoc, /openapi.json.
# true for local debugging, false for staging/production.
API_DOCS_ENABLED=true

# ==================== Auth & access control ====================
# Global auth switch for non-public routes.
# false for local free access; true for any environment requiring login.
AUTH_REQUIRED=true

# Whether /api/langgraph/* also requires bearer auth.
# false is convenient for local graph debugging; true is safer for shared envs.
LANGGRAPH_AUTH_REQUIRED=false

# Enforce x-project-id ownership checks on LangGraph assistants/threads.
# true only when you need strict project scoping and the DB/project metadata are ready.
LANGGRAPH_SCOPE_GUARD_ENABLED=false

# Access token signing secret.
# Must be a strong random string in shared or production environments.
JWT_ACCESS_SECRET=replace-with-a-strong-access-secret

# Refresh token signing secret.
# Must be different from JWT_ACCESS_SECRET in serious environments.
JWT_REFRESH_SECRET=replace-with-a-strong-refresh-secret

# Access token TTL in seconds.
# 1800 = 30 minutes.
JWT_ACCESS_TTL_SECONDS=1800

# Refresh token TTL in seconds.
# 604800 = 7 days.
JWT_REFRESH_TTL_SECONDS=604800

# Bootstrap super-admin username created when the DB is empty.
# Usually keep admin unless you have a naming convention.
BOOTSTRAP_ADMIN_USERNAME=admin

# Bootstrap super-admin password used only for first initialization.
# Set a strong password and rotate it after initial setup.
BOOTSTRAP_ADMIN_PASSWORD=replace-with-a-strong-bootstrap-password

# ==================== Database ====================
# Enable the management/auth/project database.
# true for current self-hosted auth flow.
PLATFORM_DB_ENABLED=true

# Auto-create core tables on startup.
# true for local bootstrapping, usually false once migrations manage the schema.
PLATFORM_DB_AUTO_CREATE=true

# SQLAlchemy database URL.
# Local SQLite example shown here; PostgreSQL is recommended for shared environments.
DATABASE_URL=sqlite:///./data/agent_platform_v3.db

# ==================== Logging ====================
# Directory for backend log files.
LOGS_DIR=logs

# Backend log file name.
BACKEND_LOG_FILE=backend.log

# Single log file size before rotation.
BACKEND_LOG_MAX_BYTES=10485760

# How many rotated log files to keep.
BACKEND_LOG_BACKUP_COUNT=5

# ==================== Optional graph schema discovery ====================
# Set this only if dynamic graph parameter schema should read a non-default graph source tree.
# LANGGRAPH_GRAPH_SOURCE_ROOT=/absolute/path/to/graph_src_v2
