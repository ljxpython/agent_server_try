# ==================== Runtime proxy ====================
# Use local 8123 tunnel to remote runtime 8123
LANGGRAPH_UPSTREAM_URL=http://127.0.0.1:8123
LANGGRAPH_UPSTREAM_API_KEY=

# ==================== App ====================
PROXY_TIMEOUT_SECONDS=300
PROXY_UPSTREAM_RETRIES=1
PROXY_LOG_LEVEL=INFO
API_DOCS_ENABLED=true

# Strict auth for remote-infra dev via SSH tunnel
DEV_AUTH_BYPASS_ENABLED=false
DEV_AUTH_BYPASS_MODE=fixed
DEV_AUTH_BYPASS_SUBJECT=dev-local-user
DEV_AUTH_BYPASS_EMAIL=dev-local@example.com
DEV_AUTH_BYPASS_ROLE=owner
DEV_AUTH_BYPASS_MEMBERSHIP_ENABLED=false

# ==================== Database ====================
PLATFORM_DB_ENABLED=true
PLATFORM_DB_AUTO_CREATE=false
DATABASE_URL=postgresql+psycopg://agent:<pg-password>@127.0.0.1:15432/agent_platform

# ==================== Keycloak ====================
# Use local tunnel port to remote 18080
KEYCLOAK_AUTH_ENABLED=true
KEYCLOAK_AUTH_REQUIRED=true
KEYCLOAK_ISSUER=http://127.0.0.1:28080/realms/agent-platform
KEYCLOAK_AUDIENCE=agent-proxy
KEYCLOAK_JWKS_URL=

# ==================== OpenFGA ====================
# Use local tunnel port to remote 18081
OPENFGA_ENABLED=true
OPENFGA_AUTHZ_ENABLED=true
OPENFGA_AUTO_BOOTSTRAP=false
OPENFGA_URL=http://127.0.0.1:28081
OPENFGA_STORE_ID=<store-id>
OPENFGA_MODEL_ID=<model-id>
OPENFGA_MODEL_FILE=config/openfga-models/v1.json

# ==================== Runtime policy ====================
RUNTIME_ROLE_ENFORCEMENT_ENABLED=true
